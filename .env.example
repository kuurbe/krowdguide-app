# KrowdGuide — Environment Variables
# Copy this file to .env and fill in your keys

# ── Core (required) ────────────────────────────
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here
VITE_TICKETMASTER_API_KEY=your_ticketmaster_key_here

# ── Free Tier (optional, enhances features) ────
VITE_FOURSQUARE_KEY=fsq3_your_key_here
VITE_AIRNOW_KEY=your_airnow_key_here
VITE_BANDSINTOWN_APP_ID=krowdguide
VITE_NREL_AFDC_KEY=your_nrel_key_here

# No key needed: NWS Weather, Open-Meteo, GBFS,
# USGS Earthquakes, Open Charge Map, OSM Overpass

# ── Growth Tier (feature-flagged, optional) ─────
VITE_BESTTIME_KEY=
VITE_PREDICTHQ_TOKEN=
VITE_TOMORROW_KEY=
VITE_YELP_KEY=

# ── Legacy (may be removed) ─────────────────────
VITE_EVENTBRITE_TOKEN=your_eventbrite_token_here
VITE_SERPAPI_KEY=your_serpapi_key_here
VITE_OUTSCRAPER_KEY=your_outscraper_key_here
